{
  "name": "zenlit",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start --web",
    "web": "expo start --web",
    "build": "npm run build:web",
    "build:web": "expo export --platform web",
    "preview:web": "npx serve@latest dist --single --listen 8081",
    "deploy:vercel": "npx vercel@latest --prod",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:unit": "jest --runInBand test/unit",
    "test:ui": "jest --runInBand test/ui",
    "test:onboarding": "jest --runInBand test/unit/onboardingState.test.ts",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "expo": "~57.0.2",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-manipulator": "^57.0.2",
    "expo-image-picker": "^57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.2",
    "expo-router": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "lucide-react-native": "^0.544.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^22.20.0",
    "@types/react": "~19.2.17",
    "babel-preset-expo": "^57.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true
}
