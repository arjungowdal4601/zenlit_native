{
  "expo": {
    "name": "zenlit",
    "slug": "zenlit",
    "version": "1.0.0",
    "platforms": [
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zenlit",
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zenlit to choose photos for your profile, posts, and feedback.",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zenlit to use your camera to take profile and post photos.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ]
    ],
    "extra": {
      "router": {}
    },
    "owner": "arjungowdal4601"
  }
}
